# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ─── Search / Scraping Services ──────────────────────────────────────────────
# SerpAPI: google search metadata (free 100 searches/mo, paid plans available)
SERPAPI_KEY=your-serpapi-key

# ScrapingBee: proxy rotation + JS rendering fallback
SCRAPING_BEE_KEY=your-scrapingbee-key

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-in-production-32-char-min
ADMIN_API_KEY=change-me-admin-secret

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
