# ─── Origometer backend ───────────────────────────────────────────────────────
# Public URL of the FastAPI backend. Baked into the static build at compile
# time, so the deployed JS bundle calls this directly from the browser.
# Backend must allow CORS from https://origomedia.co.
#
# Local dev:    http://127.0.0.1:8000
# Production:   https://origo-backend.onrender.com  (or your Render URL)
NEXT_PUBLIC_ORIGOMETER_API_URL=https://origo-backend.onrender.com
